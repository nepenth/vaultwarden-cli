export VW_LIVE_E2E_SERVER="https://vault.example.com"
export VW_LIVE_E2E_CLIENT_ID="user.abc"

# Prefer *_FILE for secrets so the secret values never appear in shell history.
export VW_LIVE_E2E_CLIENT_SECRET_FILE=".live-e2e/client-secret"
export VW_LIVE_E2E_MASTER_PASSWORD_FILE=".live-e2e/master-password"

# Local fixture file describing reusable folder/org/collection/read-only item IDs.
export VW_LIVE_E2E_FIXTURE_FILE=".live-e2e/fixture.json"

# Optional namespace. Reuse the same namespace for repeatable reruns against the
# same test account, or set a unique one per environment.
export VW_LIVE_E2E_NAMESPACE="default"
