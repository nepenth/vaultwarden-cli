{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vaultwarden-cli write error codes",
  "type": "object",
  "required": ["codes"],
  "properties": {
    "codes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "description", "retryable_default"],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "VALIDATION_ERROR",
              "AUTH_ERROR",
              "PERMISSION_DENIED",
              "NOT_FOUND",
              "CONFLICT_STALE_REVISION",
              "AMBIGUOUS_MATCH",
              "SERVER_ERROR"
            ]
          },
          "description": {
            "type": "string"
          },
          "retryable_default": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
